    {
      "id": 6761,
      "name": "OpenShift Virtualization (KubeVirt)",
      "description": "KubeVirt header",
      "type": "text",
      "theme": "newSolidGray",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "content": "<h2>OpenShift Virtualization (KubeVirt)</h2><p>Virtualization team view covering the KubeVirt/OpenShift Virtualization stack. HyperConverged operator rollup, VM inventory, migration state, and per-component virt daemon health.</p><p><strong>Sections:</strong> Cluster rollup &middot; Virt components &middot; Active KubeVirt alerts</p><p><strong>Source:</strong> PromQL queries via Thanos Querier. Auto-binds via category <code>OpenShift_KubeVirt</code>.</p>"
    },
    {
      "id": 6762,
      "name": "KubeVirt System Health",
      "description": "HyperConverged Operator health state across clusters (0 = healthy)",
      "type": "bigNumber",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "bigNumberInfo": {
        "dataPoints": [
          {
            "deviceGroupFullPath": "*",
            "deviceDisplayName": "*",
            "dataSourceFullName": "KubeVirt Cluster Overview (KubeVirt_Cluster_Overview)",
            "instanceName": "*",
            "dataPointName": "system_health",
            "name": "system_health",
            "aggregateFunction": "max"
          }
        ],
        "virtualDataPoints": [],
        "counters": [],
        "bigNumberItems": [
          {
            "dataPointName": "system_health",
            "bottomLabel": "",
            "rightLabel": "KubeVirt Health (0=OK)",
            "position": 1,
            "rounding": 0,
            "colorThresholds": null,
            "useCommaSeparators": false,
            "actions": []
          }
        ]
      }
