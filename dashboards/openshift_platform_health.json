    {
      "id": 6657,
      "name": "OpenShift Platform Health",
      "description": "Platform health header",
      "type": "text",
      "theme": "newSolidGray",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "content": "<h2>OpenShift Platform Health</h2><p>Deep-dive operational view of the OpenShift control plane (OCP) and the etcd quorum that backs it. Designed for platform engineering: if anything here is off, end-user workloads will feel it next.</p><p><strong>Sections:</strong> Control plane alarms &middot; API server &amp; scheduler performance &middot; Etcd cluster health &middot; Etcd member performance &middot; Certificates &amp; monitoring &middot; Active platform alerts</p><p><strong>Source:</strong> PromQL queries against each cluster's Thanos Querier, aggregated across all devices with categories <code>OpenShift_OCP</code> and <code>OpenShift_Etcd</code>.</p>"
    },
    {
      "id": 6658,
      "name": "Degraded Operators",
      "description": "ClusterOperators reporting Degraded=True across all OCP clusters",
      "type": "bigNumber",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "bigNumberInfo": {
        "dataPoints": [
          {
            "deviceGroupFullPath": "*",
            "deviceDisplayName": "*",
            "dataSourceFullName": "OCP Operator Overview (OCP_Operator_Overview)",
            "instanceName": "*",
            "dataPointName": "operators_degraded",
            "name": "operators_degraded",
            "aggregateFunction": "sum"
          }
        ],
        "virtualDataPoints": [],
        "counters": [],
        "bigNumberItems": [
          {
            "dataPointName": "operators_degraded",
            "bottomLabel": "",
            "rightLabel": "Degraded Operators",
            "position": 1,
            "rounding": 0,
            "colorThresholds": null,
            "useCommaSeparators": false,
            "actions": []
          }
        ]
      }
    },
