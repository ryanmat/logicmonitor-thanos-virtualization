  "widgets_full": [
    {
      "id": 6646,
      "name": "OpenShift Thanos Overview",
      "description": "Executive summary header",
      "type": "text",
      "theme": "solidPurple",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "content": "<h2>OpenShift Thanos Monitoring Suite</h2><p>Executive health snapshot across all deployed OpenShift monitoring suites. Each tile shows the current cluster-level health signal from the corresponding Thanos-backed DataSource. Tiles turn red when attention is needed.</p><p><strong>Suites covered:</strong> OCP (OperatorHub) &middot; Etcd &middot; KubeVirt &middot; OpenShift Data Foundation &middot; Advanced Cluster Management &middot; GitOps (ArgoCD) &middot; Portworx</p><p><strong>Source:</strong> PromQL queries against each cluster's Thanos Querier. Devices auto-bind to widgets via <code>system.categories</code> set by the <code>addCategory_OpenShift_Thanos</code> PropertySource.</p>"
    },
    {
      "id": 6647,
      "name": "OCP Operators Degraded",
      "description": "Count of degraded ClusterOperators across all OCP clusters (0 = healthy)",
      "type": "bigNumber",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "bigNumberInfo": {
        "dataPoints": [
          {
            "deviceGroupFullPath": "*",
            "deviceDisplayName": "*",
            "dataSourceFullName": "OCP Operator Overview (OCP_Operator_Overview)",
            "instanceName": "*",
            "dataPointName": "operators_degraded",
            "name": "operators_degraded",
            "aggregateFunction": "sum"
          }
        ],
        "virtualDataPoints": [],
        "counters": [],
        "bigNumberItems": [
          {
            "dataPointName": "operators_degraded",
            "bottomLabel": "",
            "rightLabel": "Degraded Operators",
            "position": 1,
            "rounding": 0,
            "colorThresholds": null,
            "useCommaSeparators": false,
            "actions": []
          }
        ]
      }
    },
