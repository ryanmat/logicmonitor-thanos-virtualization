      "id": 6760,
      "name": "Active GitOps Alerts",
      "description": "Live alerts scoped to ArgoCD_* DataSources",
      "type": "alert",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {
        "isShowAll": false,
        "showFilter": true,
