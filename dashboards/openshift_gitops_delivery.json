          },
          {
            "visible": true,
            "columnLabel": "Datapoint",
            "columnKey": "alert-datapoint"
          },
          {
            "visible": true,
            "columnLabel": "Value",
            "columnKey": "alert-value"
          },
          {
            "visible": true,
            "columnLabel": "Static Threshold",
            "columnKey": "alert-static-threshold"
          }
        ],
        "fontsize": "normal-font",
        "sort": "-startEpoch"
      },
