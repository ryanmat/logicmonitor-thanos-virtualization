        "group": "*",
        "host": "",
        "dataSource": "ArgoCD_*",
        "instance": "",
        "dataPoint": "",
        "severity": "",
        "acked": "all",
        "sdted": "all",
        "rule": "",
        "chain": "",
        "cleared": "no",
        "keyword": "",
        "dependencyRole": "",
        "dependencyRoutingState": "",
        "anomaly": "all"
