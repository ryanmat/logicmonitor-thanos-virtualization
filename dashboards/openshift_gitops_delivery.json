    {
      "id": 6747,
      "name": "OpenShift GitOps Delivery",
      "description": "GitOps header",
      "type": "text",
      "theme": "newSolidGray",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "content": "<h2>OpenShift GitOps Delivery</h2><p>App-owner view of the GitOps sync path: ArgoCD fleets, controller reconcile performance, repo-server git activity, and gRPC server health.</p><p><strong>Sections:</strong> ArgoCD app inventory &middot; Sync + controller performance &middot; Repo + server &middot; Active ArgoCD alerts</p><p><strong>Source:</strong> PromQL queries via Thanos Querier. Auto-binds via category <code>OpenShift_GitOps</code>.</p>"
    },
    {
      "id": 6748,
      "name": "ArgoCD Total Apps",
      "description": "Total ArgoCD applications across all GitOps fleets",
      "type": "bigNumber",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "bigNumberInfo": {
        "dataPoints": [
          {
            "deviceGroupFullPath": "*",
            "deviceDisplayName": "*",
            "dataSourceFullName": "ArgoCD Sync Overview (ArgoCD_Sync_Overview)",
            "instanceName": "*",
            "dataPointName": "total_apps",
            "name": "total_apps",
            "aggregateFunction": "sum"
          }
        ],
        "virtualDataPoints": [],
        "counters": [],
        "bigNumberItems": [
          {
            "dataPointName": "total_apps",
            "bottomLabel": "",
            "rightLabel": "Total Apps",
            "position": 1,
            "rounding": 0,
            "colorThresholds": null,
            "useCommaSeparators": false,
            "actions": []
          }
        ]
      }
    },
