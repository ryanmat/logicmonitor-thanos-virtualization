    {
      "id": 6741,
      "name": "Active ACM Alerts",
      "description": "Live alerts scoped to ACM_* DataSources",
      "type": "alert",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {
        "isShowAll": false,
        "showFilter": true,
        "columns": [
          {
            "visible": true,
            "columnLabel": "Severity",
            "columnKey": "alert-severity"
          },
          {
            "visible": true,
            "columnLabel": "Began",
            "columnKey": "alert-began"
          },
          {
            "visible": true,
            "columnLabel": "Resource/Website",
            "columnKey": "alert-device"
          },
          {
            "visible": true,
            "columnLabel": "LogicModule",
            "columnKey": "alert-datasource"
          },
          {
            "visible": true,
            "columnLabel": "Instance",
            "columnKey": "alert-datasource-instance"
          },
          {
            "visible": true,
            "columnLabel": "Datapoint",
            "columnKey": "alert-datapoint"
          },
          {
            "visible": true,
            "columnLabel": "Value",
            "columnKey": "alert-value"
          },
          {
            "visible": true,
            "columnLabel": "Static Threshold",
            "columnKey": "alert-static-threshold"
          }
        ],
        "fontsize": "normal-font",
        "sort": "-startEpoch"
      },
      "filters": {
        "group": "*",
        "host": "",
        "dataSource": "ACM_*",
        "instance": "",
        "dataPoint": "",
        "severity": "",
        "acked": "all",
        "sdted": "all",
        "rule": "",
        "chain": "",
        "cleared": "no",
        "keyword": "",
        "dependencyRole": "",
        "dependencyRoutingState": "",
        "anomaly": "all"
      }
    }
