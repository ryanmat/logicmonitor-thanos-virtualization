    {
      "id": 6724,
      "name": "Multi-Cluster Fleet (ACM)",
      "description": "Fleet header",
      "type": "text",
      "theme": "newSolidGray",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "content": "<h2>Multi-Cluster Fleet (ACM)</h2><p>Fleet operations view of clusters under management by Red Hat Advanced Cluster Management. Each hub tile reports fleet-wide roll-ups so the picture scales with the customer's managed estate.</p><p><strong>Sections:</strong> Hub fleet inventory &middot; Hub + controller health &middot; Hub component replicas &middot; Thanos observability stack &middot; Active ACM alerts</p><p><strong>Source:</strong> PromQL queries against the ACM hub's Thanos Querier. Auto-binds via category <code>OpenShift_ACM</code>.</p>"
    },
    {
      "id": 6725,
      "name": "Managed Clusters Total",
      "description": "Total managed clusters registered with all ACM hubs",
      "type": "bigNumber",
      "theme": "newSolidDarkBlue",
      "interval": 5,
      "timescale": "day",
      "displaySettings": {},
      "bigNumberInfo": {
        "dataPoints": [
          {
            "deviceGroupFullPath": "*",
            "deviceDisplayName": "*",
            "dataSourceFullName": "ACM Hub Overview (ACM_Hub_Overview)",
            "instanceName": "*",
            "dataPointName": "clusters_total",
            "name": "clusters_total",
            "aggregateFunction": "sum"
          }
        ],
        "virtualDataPoints": [],
        "counters": [],
        "bigNumberItems": [
          {
            "dataPointName": "clusters_total",
            "bottomLabel": "",
            "rightLabel": "Managed Clusters Total",
            "position": 1,
            "rounding": 0,
            "colorThresholds": null,
            "useCommaSeparators": false,
            "actions": []
          }
        ]
      }
    },
